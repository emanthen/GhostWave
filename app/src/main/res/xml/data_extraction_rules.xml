<?xml version="1.0" encoding="utf-8"?>
<!--
    Explicitly exclude ALL app data from Android backup / cloud extraction.
    GhostWave's encrypted DB and Signal session keys must never leave the device
    through Android's backup mechanism — they are hardware-keystore-bound anyway,
    but we also declare this here for defence-in-depth.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
