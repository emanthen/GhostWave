<?xml version="1.0" encoding="utf-8"?>
<!--
  Network Security Config — GhostWave
  Global policy: NO cleartext traffic. All HTTP is blocked.
  Only HTTPS + WebSocket-over-TLS + DTLS (WebRTC) are allowed.
  STUN/TURN servers communicate over TLS; local loopback (IPFS Kubo)
  is exempt because it never leaves the device.
-->
<network-security-config>

    <!-- Default: block all cleartext globally -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <!-- Trust system CAs for all external traffic -->
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!--
      Local loopback exemption: IPFS Kubo node runs on 127.0.0.1.
      Traffic never leaves the device, so cleartext here is acceptable.
    -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>

    <!--
      GhostWave API (promo validation) — HTTPS only, pins the
      leaf cert SHA-256. Update pin when cert rotates.
      Pin backup included so rotation can be planned.
    -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">api.ghostwave.app</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
        <!-- Certificate pinning (update pins before release) -->
        <!--
        <pin-set expiration="2026-12-31">
            <pin digest="SHA-256">AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=</pin>
            <pin digest="SHA-256">BBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBB=</pin>
        </pin-set>
        -->
    </domain-config>

</network-security-config>
